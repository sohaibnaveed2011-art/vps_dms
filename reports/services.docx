namespace App\Services\Core;

use App\Models\Core\SectionCategory;
use App\Exceptions\NotFoundException;
use Illuminate\Contracts\Pagination\LengthAwarePaginator;

class SectionCategoryService
{
    /* =========================================================
     | Pagination
     ========================================================= */

    public function paginate(
    array $filters = [],
    int $perPage = 15
): LengthAwarePaginator {

    $query = SectionCategory::query();

    // Multi-tenant filter
    if (isset($filters['organization_id'])) {
        $query->where('organization_id', $filters['organization_id']);
    }

    // Optional active filter
    if (isset($filters['is_active'])) {
        $query->where('is_active', (bool) $filters['is_active']);
    }

    // Search support
    if (! empty($filters['search'])) {
        $query->where(function ($q) use ($filters) {
            $q->where('name', 'like', '%'.$filters['search'].'%')
              ->orWhere('code', 'like', '%'.$filters['search'].'%');
        });
    }

    return $query->latest()->paginate($perPage);
}


    /* =========================================================
     | Retrieval
     ========================================================= */

    public function find(int $id): SectionCategory
    {
        $category = SectionCategory::with([
            'organization',
            'warehouseSections',
        ])->find($id);

        if (! $category) {
            throw new NotFoundException('Section Category not found.');
        }

        return $category;
    }

    public function findWithTrashed(int $id): SectionCategory
    {
        $category = SectionCategory::withTrashed()
            ->with(['organization', 'warehouseSections'])
            ->find($id);

        if (! $category) {
            throw new NotFoundException('Section Category not found.');
        }

        return $category;
    }

    /* =========================================================
     | Mutations
     ========================================================= */

    public function create(array $data): SectionCategory
    {
        return SectionCategory::create($data);
    }

    public function update(int $id, array $data): SectionCategory
    {
        $category = $this->find($id);

        $category->update($data);

        return $category->fresh();
    }

    public function delete(int $id): void
    {
        $category = $this->find($id);

        $category->delete();
    }

    public function forceDelete(int $id): void
    {
        $category = $this->findWithTrashed($id);
        $category->forceDelete();
    }

    public function restore(int $id): SectionCategory
    {
        $category = $this->findWithTrashed($id);

        if (! $category->trashed()) {
            throw new NotFoundException(
                'Section Category is not deleted.'
            );
        }

        $category->restore();

        return $category->fresh();
    }
}

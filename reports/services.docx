     | Mutations
     ========================================================= */

    public function create(array $data): OutletSection
    {
        return OutletSection::create($data);
    }

    public function update(int $id, array $data): OutletSection
    {
        $section = $this->find($id);

        $section->update($data);

        return $section->fresh();
    }

    public function delete(int $id): void
    {
        $this->find($id)->delete();
    }

    public function restore(int $id): OutletSection
    {
        $section = $this->findWithTrashed($id);

        if (! $section->trashed()) {
            throw new NotFoundException(
                'Outlet Section not found or not deleted.'
            );
        }

        $section->restore();

        return $section->fresh();
    }


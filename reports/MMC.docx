namespace App\Http\Controllers\v1\api\Inventory;

use App\Exceptions\ForbiddenException;
use App\Http\Controllers\v1\api\BaseApiController;
use App\Http\Requests\Inventory\StoreVariationRequest;
use App\Http\Requests\Inventory\UpdateVariationRequest;
use App\Http\Resources\Inventory\VariationResource;
use App\Services\Inventory\VariationService;
use App\Guards\PolicyGuard;
use Illuminate\Http\Request;

class VariationController extends BaseApiController
{
    protected array $permissions = [
        'index'       => 'inventory.variation.view',
        'store'       => 'inventory.variation.create',
        'show'        => 'inventory.variation.show',
        'update'      => 'inventory.variation.update',
        'destroy'     => 'inventory.variation.destroy',
        'restore'     => 'inventory.variation.restore',
        'forceDelete' => 'inventory.variation.forceDelete',
    ];

    public function __construct(
        protected VariationService $service,
        protected PolicyGuard $policyGuard
    ) {
        parent::__construct(app(\App\Services\Auth\AuthorizationService::class));
    }

    protected function context(Request $request)
    {
        return $request->user()->activeContext()
            ?? throw new ForbiddenException('No active context.');
    }

    /* =========================================================
     | LIST
     ========================================================= */

    public function index(Request $request)
    {
        $this->authorizeAction($request);
        $context = $this->context($request);

        $perPage = $this->perPage($request);

        $items = $this->service->paginate(
            $context->organization_id,
            $perPage
        );

        return $this->success(
            VariationResource::collection($items->items()),
            [
                'total'        => $items->total(),
                'per_page'     => $items->perPage(),
                'current_page' => $items->currentPage(),
            ]
        );
    }

    /* =========================================================
     | CREATE
     ========================================================= */

    public function store(StoreVariationRequest $request)
    {
        $this->authorizeAction($request);
        $context = $this->context($request);

        $this->policyGuard->requireFeature(
            $context->organization_id,
            'inventory'
        );

        $variation = $this->service->create(
            $request->validated()
        );

        return $this->created(
            new VariationResource($variation)
        );
    }

    /* =========================================================
     | SHOW
     ========================================================= */

    public function show(Request $request, int $id)
    {
        $context = $this->context($request);

        $variation = $this->service->find(
            $context->organization_id,
            $id
        );

        $this->authorizeAction($request, $variation);

        return $this->success(
            new VariationResource($variation)
        );
    }

    /* =========================================================
     | UPDATE
     ========================================================= */

    public function update(UpdateVariationRequest $request, int $id)
    {
        $context = $this->context($request);

        $variation = $this->service->find(
            $context->organization_id,
            $id
        );

        $this->authorizeAction($request, $variation);

        $updated = $this->service->update(
            $variation,
            $request->validated()
        );

        return $this->success(
            new VariationResource($updated)
        );
    }

    /* =========================================================
     | DELETE (Soft)
     ========================================================= */

    public function destroy(Request $request, int $id)
    {
        $context = $this->context($request);

        $variation = $this->service->find(
            $context->organization_id,
            $id
        );

        $this->authorizeAction($request, $variation);

        $this->service->delete($variation);

        return $this->deleted('Variation deleted successfully.');
    }

    /* =========================================================
     | RESTORE
     ========================================================= */

    public function restore(Request $request, int $id)
    {
        $context = $this->context($request);

        $variation = $this->service->findWithTrashed(
            $context->organization_id,
            $id
        );

        $this->authorizeAction($request, $variation);

        $this->service->restore($variation);

        return $this->success([
            'message' => 'Variation restored successfully.'
        ]);
    }

    /* =========================================================
     | FORCE DELETE
     ========================================================= */

    public function forceDelete(Request $request, int $id)
    {
        $context = $this->context($request);

        $variation = $this->service->findWithTrashed(
            $context->organization_id,
            $id
        );

        $this->authorizeAction($request, $variation);

        $this->service->forceDelete($variation);

        return $this->deleted('Variation permanently deleted.');
    }
}

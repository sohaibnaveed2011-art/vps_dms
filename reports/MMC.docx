namespace App\Http\Controllers\v1\api\Core;

use App\Exceptions\ForbiddenException;
use App\Exceptions\NotFoundException;
use App\Guards\PolicyGuard;
use App\Http\Controllers\v1\api\BaseApiController;
use App\Http\Requests\Core\StoreOutletSectionRequest;
use App\Http\Requests\Core\UpdateOutletSectionRequest;
use App\Http\Resources\Core\OutletSectionResource;
use App\Services\Core\OutletSectionService;
use Illuminate\Http\Request;

class OutletSectionController extends BaseApiController
{
    protected array $permissions = [
        'index' => 'core.outletSection.view',
        'store' => 'core.outletSection.create',
        'show' => 'core.outletSection.show',
        'update' => 'core.outletSection.update',
        'destroy' => 'core.outletSection.destroy',
        'restore' => 'core.outletSection.restore',
        'forceDelete' => 'core.outletSection.forceDelete',
    ];

    public function __construct(
        protected OutletSectionService $service,
        protected PolicyGuard $policyGuard
    ) {
        parent::__construct(app(\App\Services\Auth\AuthorizationService::class));
    }

    /* =========================================================
     | List
     ========================================================= */

    public function index(Request $request)
    {
        $this->authorizeAction($request);

        $user = $request->user();

        $filters = $request->only([
            'outlet_id',
            'is_pos_counter',
            'is_active',
            'search',
        ]);

        $this->restrictToContext($request, $filters);

        $perPage = min(
            max((int) $request->input('per_page', 15), 1),
            100
        );

        $sections = $this->service->paginate(
            $filters,
            $perPage
        );

        return $this->success(
            OutletSectionResource::collection($sections->items()),
            [
                'total' => $sections->total(),
                'per_page' => $sections->perPage(),
                'current_page' => $sections->currentPage(),
            ]
        );
    }

    /* =========================================================
     | Create
     ========================================================= */

    public function store(StoreOutletSectionRequest $request)
    {
        $this->authorizeAction($request);

        $user = $request->user();

        if (! $user->is_admin) {
            $context = $user->activeContext();

            if (! $context) {
                throw new ForbiddenException('No active context.');
            }

            // 🔐 POLICY: outlets must be enabled
            $this->policyGuard->requireHierarchy(
                $context->organization_id,
                'outlets'
            );
        }

        $this->service->create($request->validated());

        return $this->created(
            ['message' => 'Outlet Section created successfully.']
        );
    }

    /* =========================================================
     | Show
     ========================================================= */

    public function show(Request $request, int $id)
    {
        $section = $this->service->find($id);

        $this->authorizeAction($request, $section);

        return $this->success(
            new OutletSectionResource($section)
        );
    }

    /* =========================================================
     | Update
     ========================================================= */

    public function update(UpdateOutletSectionRequest $request, int $id)
    {
        $section = $this->service->find($id);

        $this->authorizeAction($request, $section);

        $this->service->update($id, $request->validated());

        return $this->success(
            ['message' => 'Outlet Section updated successfully.']
        );
    }

    /* =========================================================
     | Soft Delete
     ========================================================= */

    public function destroy(Request $request, int $id)
    {
        $section = $this->service->find($id);

        $this->authorizeAction($request, $section);

        $this->service->delete($id);

        return $this->deleted(
            'Outlet Section deleted successfully.'
        );
    }

    /* =========================================================
     | Force Delete
     ========================================================= */

    public function forceDelete(Request $request, int $id)
    {
        $section = $this->service->findWithTrashed($id);

        $this->authorizeAction($request, $section);

        $this->service->forceDelete($id);

        return $this->deleted(
            'Outlet Section permanently deleted.'
        );
    }

    /* =========================================================
     | Restore
     ========================================================= */

    public function restore(Request $request, int $id)
    {
        $section = $this->service->findWithTrashed($id);

        if (! $section->trashed()) {
            throw new NotFoundException(
                'Outlet Section not found or not deleted.'
            );
        }

        $this->authorizeAction($request, $section);

        $this->service->restore($id);

        return $this->success(
            ['message' => 'Outlet Section restored successfully.']
        );
    }
}

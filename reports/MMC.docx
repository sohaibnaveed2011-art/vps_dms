namespace App\Http\Controllers\v1\api\Inventory;

use App\Http\Controllers\Controller;
use App\Http\Requests\Inventory\StoreInventoryConditionRequest;
use App\Http\Requests\Inventory\UpdateInventoryConditionRequest;
use App\Http\Resources\Inventory\InventoryConditionResource;
use App\Services\Inventory\Core\ConditionService;
use Illuminate\Http\Request;

class InventoryConditionController extends Controller
{
    public function __construct(
        protected ConditionService $service
    ) {}

    protected function orgId(Request $request): int
    {
        return $request->user()->activeContext()->organization_id;
    }

    public function index(Request $request)
    {
        $conditions = $this->service->paginate(
            $this->orgId($request),
            min((int) $request->input('per_page', 15), 100)
        );

        return InventoryConditionResource::collection($conditions);
    }

    public function store(StoreInventoryConditionRequest $request)
    {
        $condition = $this->service->create($request->validated());

        return new InventoryConditionResource($condition);
    }

    public function show(Request $request, int $id)
    {
        $condition = $this->service->find($this->orgId($request), $id);

        return new InventoryConditionResource($condition);
    }

    public function update(UpdateInventoryConditionRequest $request, int $id)
    {
        $condition = $this->service->find($this->orgId($request), $id);

        $this->service->update($condition, $request->validated());

        return new InventoryConditionResource($condition);
    }

    public function destroy(Request $request, int $id)
    {
        $condition = $this->service->find($this->orgId($request), $id);

        $this->service->delete($condition);

        return response()->json(['message' => 'Condition deleted successfully.']);
    }

    public function restore(Request $request, int $id)
    {
        $condition = $this->service->findWithTrashed($this->orgId($request), $id);

        $this->service->restore($condition);

        return response()->json(['message' => 'Condition restored successfully.']);
    }

    public function forceDelete(Request $request, int $id)
    {
        $condition = $this->service->findWithTrashed($this->orgId($request), $id);

        $this->service->forceDelete($condition);

        return response()->json(['message' => 'Condition permanently deleted.']);
    }
}

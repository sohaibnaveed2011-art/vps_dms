namespace App\Http\Controllers\v1\api\Inventory;

use App\Exceptions\ForbiddenException;
use App\Http\Controllers\v1\api\BaseApiController;
use App\Http\Requests\Inventory\StoreVariationValueRequest;
use App\Http\Requests\Inventory\UpdateVariationValueRequest;
use App\Http\Resources\Inventory\VariationValueResource;
use App\Services\Inventory\VariationValueService;
use App\Guards\PolicyGuard;
use Illuminate\Http\Request;

class VariationValueController extends BaseApiController
{
    protected array $permissions = [
        'index'       => 'inventory.variationValue.view',
        'store'       => 'inventory.variationValue.create',
        'show'        => 'inventory.variationValue.show',
        'update'      => 'inventory.variationValue.update',
        'destroy'     => 'inventory.variationValue.destroy',
        'restore'     => 'inventory.variationValue.restore',
        'forceDelete' => 'inventory.variationValue.forceDelete',
    ];

    public function __construct(
        protected VariationValueService $service,
        protected PolicyGuard $policyGuard
    ) {
        parent::__construct(app(\App\Services\Auth\AuthorizationService::class));
    }

    protected function context(Request $request)
    {
        return $request->user()->activeContext()
            ?? throw new ForbiddenException('No active context.');
    }

    /* =========================================================
     | LIST (By Variation)
     ========================================================= */

    public function index(Request $request, int $variationId)
    {
        $this->authorizeAction($request);

        $perPage = $this->perPage($request);

        $items = $this->service->paginate(
            $variationId,
            $perPage
        );

        return $this->success(
            VariationValueResource::collection($items->items()),
            [
                'total'        => $items->total(),
                'per_page'     => $items->perPage(),
                'current_page' => $items->currentPage(),
            ]
        );
    }

    /* =========================================================
     | CREATE
     ========================================================= */

    public function store(StoreVariationValueRequest $request)
    {
        $this->authorizeAction($request);

        $value = $this->service->create(
            $request->validated()
        );

        return $this->created(
            new VariationValueResource($value)
        );
    }

    /* =========================================================
     | SHOW
     ========================================================= */

    public function show(Request $request, int $variationId, int $id)
    {
        $value = $this->service->find($variationId, $id);

        $this->authorizeAction($request, $value);

        return $this->success(
            new VariationValueResource($value)
        );
    }

    /* =========================================================
     | UPDATE
     ========================================================= */

    public function update(UpdateVariationValueRequest $request, int $variationId, int $id)
    {
        $value = $this->service->find($variationId, $id);

        $this->authorizeAction($request, $value);

        $updated = $this->service->update(
            $value,
            $request->validated()
        );

        return $this->success(
            new VariationValueResource($updated)
        );
    }

    /* =========================================================
     | DELETE
     ========================================================= */

    public function destroy(Request $request, int $variationId, int $id)
    {
        $value = $this->service->find($variationId, $id);

        $this->authorizeAction($request, $value);

        $this->service->delete($value);

        return $this->deleted('Variation value deleted successfully.');
    }

    /* =========================================================
     | RESTORE
     ========================================================= */

    public function restore(Request $request, int $variationId, int $id)
    {
        $value = $this->service->findWithTrashed($variationId, $id);

        $this->authorizeAction($request, $value);

        $this->service->restore($value);

        return $this->success([
            'message' => 'Variation value restored successfully.'
        ]);
    }

    /* =========================================================
     | FORCE DELETE
     ========================================================= */

    public function forceDelete(Request $request, int $variationId, int $id)
    {
        $value = $this->service->findWithTrashed($variationId, $id);

        $this->authorizeAction($request, $value);

        $this->service->forceDelete($value);

        return $this->deleted('Variation value permanently deleted.');
    }
}

namespace App\Http\Controllers\v1\api\Pricing;

use Illuminate\Http\Request;
use App\Services\Pricing\PriceSimulationService;
use App\Http\Controllers\v1\api\BaseApiController;
use App\Http\Requests\Pricing\PriceSimulationRequest;

class PriceSimulationController extends BaseApiController
{
    protected array $permissions = [
        'simulate' => 'pricing.simulate',
    ];

    public function __construct(
        protected PriceSimulationService $service
    ) {
        parent::__construct(app(\App\Services\Auth\AuthorizationService::class));
    }

    public function simulate(PriceSimulationRequest $request)
    {
        $this->authorizeAction($request);

        $result = $this->service->simulate(
            $this->context($request),
            $request->validated()
        );

        return $this->success($result);
    }
}
<?php

namespace App\Http\Controllers\v1\api\Inventory;

use App\Exceptions\ForbiddenException;
use App\Http\Controllers\v1\api\BaseApiController;
use App\Http\Requests\Inventory\StoreProductRequest;
use App\Http\Requests\Inventory\UpdateProductRequest;
use App\Http\Resources\Inventory\ProductResource;
use App\Services\Inventory\ProductService;
use App\Guards\PolicyGuard;
use Illuminate\Http\Request;

class ProductController extends BaseApiController
{
    protected array $permissions = [
        'index'       => 'inventory.product.view',
        'store'       => 'inventory.product.create',
        'show'        => 'inventory.product.show',
        'update'      => 'inventory.product.update',
        'destroy'     => 'inventory.product.destroy',
        'restore'     => 'inventory.product.restore',
        'forceDelete' => 'inventory.product.forceDelete',
    ];

    public function __construct(
        protected ProductService $service,
        protected PolicyGuard $policyGuard
    ) {
        parent::__construct(app(\App\Services\Auth\AuthorizationService::class));
    }

    protected function context(Request $request)
    {
        return $request->user()->activeContext()
            ?? throw new ForbiddenException('No active context.');
    }

    public function index(Request $request)
    {
        $this->authorizeAction($request);
        $context = $this->context($request);

        $items = $this->service->paginate(
            $context->organization_id,
            $this->perPage($request)
        );

        return $this->success(
            ProductResource::collection($items->items()),
            [
                'total' => $items->total(),
                'per_page' => $items->perPage(),
                'current_page' => $items->currentPage(),
            ]
        );
    }

    public function store(StoreProductRequest $request)
    {
        $this->authorizeAction($request);
        $context = $this->context($request);

        $this->policyGuard->requireFeature(
            $context->organization_id,
            'inventory'
        );

        $product = $this->service->create(
            $request->validated()
        );

        return $this->created(new ProductResource($product));
    }

    public function update(UpdateProductRequest $request, int $id)
    {
        $context = $this->context($request);

        $product = $this->service->find(
            $context->organization_id,
            $id
        );

        $this->authorizeAction($request, $product);

        $updated = $this->service->update(
            $product,
            $request->validated()
        );

        return $this->success(new ProductResource($updated));
    }

    public function destroy(Request $request, int $id)
    {
        $context = $this->context($request);

        $product = $this->service->find(
            $context->organization_id,
            $id
        );

        $this->authorizeAction($request, $product);

        $this->service->delete($product);

        return $this->deleted('Product deleted successfully.');
    }

    public function restore(Request $request, int $id)
    {
        $context = $this->context($request);

        $product = $this->service->findWithTrashed(
            $context->organization_id,
            $id
        );

        $this->authorizeAction($request, $product);

        $this->service->restore($product);

        return $this->success([
            'message' => 'Product restored successfully.'
        ]);
    }

    public function forceDelete(Request $request, int $id)
    {
        $context = $this->context($request);

        $product = $this->service->findWithTrashed(
            $context->organization_id,
            $id
        );

        $this->authorizeAction($request, $product);

        $this->service->forceDelete($product);

        return $this->deleted('Product permanently deleted.');
    }
}
<?php

namespace App\Http\Controllers\v1\api\Inventory;

use App\Exceptions\ForbiddenException;
use App\Http\Controllers\v1\api\BaseApiController;
use App\Http\Resources\Inventory\ProductImageResource;
use App\Models\Inventory\Product;
use App\Models\Inventory\ProductImage;
use App\Services\Inventory\ProductImageService;
use Illuminate\Http\Request;

class ProductImageController extends BaseApiController
{
    protected array $permissions = [
        'index'       => 'inventory.product.view',
        'store'       => 'inventory.product.update',
        'setPrimary'  => 'inventory.product.update',
        'destroy'     => 'inventory.product.update',
        'restore'     => 'inventory.product.update',
        'forceDelete' => 'inventory.product.forceDelete',
    ];

    public function __construct(
        protected ProductImageService $service
    ) {
        parent::__construct(app(\App\Services\Auth\AuthorizationService::class));
    }

    protected function context(Request $request)
    {
        return $request->user()->activeContext()
            ?? throw new ForbiddenException('No active context.');
    }

    /* =========================================================
     | LIST IMAGES
     ========================================================= */

    public function index(Request $request, int $productId)
    {
        $this->authorizeAction($request);

        $context = $this->context($request);

        $product = Product::where('organization_id', $context->organization_id)
            ->findOrFail($productId);

        return $this->success(
            ProductImageResource::collection(
                $this->service->list($product)
            )
        );
    }

    /* =========================================================
     | UPLOAD
     ========================================================= */

    public function store(Request $request, int $productId)
    {
        $this->authorizeAction($request);

        $request->validate([
            'image' => ['required', 'image', 'max:5120']
        ]);

        $context = $this->context($request);

        $product = Product::where('organization_id', $context->organization_id)
            ->findOrFail($productId);

        $image = $this->service->upload(
            $product,
            $request->file('image')
        );

        return $this->created(new ProductImageResource($image));
    }

    /* =========================================================
     | SET PRIMARY
     ========================================================= */

    public function setPrimary(Request $request, int $imageId)
    {
        $this->authorizeAction($request);

        $image = ProductImage::findOrFail($imageId);

        $updated = $this->service->setPrimary($image);

        return $this->success(
            new ProductImageResource($updated)
        );
    }

    /* =========================================================
     | DELETE
     ========================================================= */

    public function destroy(Request $request, int $imageId)
    {
        $this->authorizeAction($request);

        $image = ProductImage::findOrFail($imageId);

        $this->service->delete($image);

        return $this->deleted('Image deleted successfully.');
    }

    /* =========================================================
     | RESTORE
     ========================================================= */

    public function restore(Request $request, int $imageId)
    {
        $this->authorizeAction($request);

        $image = ProductImage::withTrashed()
            ->findOrFail($imageId);

        $this->service->restore($image);

        return $this->success([
            'message' => 'Image restored successfully.'
        ]);
    }

    /* =========================================================
     | FORCE DELETE
     ========================================================= */

    public function forceDelete(Request $request, int $imageId)
    {
        $this->authorizeAction($request);

        $image = ProductImage::withTrashed()
            ->findOrFail($imageId);

        $this->service->forceDelete($image);

        return $this->deleted('Image permanently deleted.');
    }
}

        'store' => 'core.sectionCategory.create',
        'show' => 'core.sectionCategory.show',
        'update' => 'core.sectionCategory.update',
        'destroy' => 'core.sectionCategory.destroy',
        'forceDelete' => 'core.sectionCategory.forceDelete',
        'restore' => 'core.sectionCategory.restore',
    ];

    public function __construct(
        protected SectionCategoryService $service,
        protected PolicyGuard $policyGuard
    ) {
        parent::__construct(app(\App\Services\Auth\AuthorizationService::class));
    }

    /* =========================================================
     | List
     ========================================================= */

    public function index(Request $request)
    {
        $this->authorizeAction($request);

        $filters = $request->only([
            'search',
            'is_active',
        ]);

        $this->restrictToContext($request, $filters);

        $perPage = min(
            max((int) $request->input('per_page', 15), 1),
            100
        );

        $categories = $this->service->paginate(
            $filters,
            $perPage
        );

        return $this->success(
            SectionCategoryResource::collection($categories->items()),
            [
                'total' => $categories->total(),
                'per_page' => $categories->perPage(),
                'current_page' => $categories->currentPage(),
            ]
        );
    }

    /* =========================================================
     | Create
     ========================================================= */

    public function store(StoreSectionCategoryRequest $request)
    {
        $this->authorizeAction($request);

        $this->service->create($request->validated());

        return $this->created(
            ['message' => 'Section Category created successfully']
        );

    }

    /* =========================================================
     | Show
     ========================================================= */

    public function show(Request $request, int $id)
    {
        $category = $this->service->find($id);

        $this->authorizeAction($request, $category);

        return $this->success(
            new SectionCategoryResource($category)
        );
    }

    /* =========================================================
     | Update
     ========================================================= */

    public function update(UpdateSectionCategoryRequest $request, int $id)
    {
        $category = $this->service->find($id);

        $this->authorizeAction($request, $category);

        $this->service->update($id, $request->validated());

        return $this->success(
            ['message' => 'Section Category updated successfully']
        );
    }

    /* =========================================================
     | Soft Delete
     ========================================================= */

    public function destroy(Request $request, int $id)
    {
        $category = $this->service->find($id);

        $this->authorizeAction($request, $category);

        $this->service->delete($id);

        return $this->deleted('Section Category deleted successfully.');
    }

    /* =========================================================
     | Restore
     ========================================================= */

    public function restore(Request $request, int $id)
    {
        $category = $this->service->findWithTrashed($id);

        $this->authorizeAction($request, $category);

        $restored = $this->service->restore($id);

        return $this->success(
            ['message' => 'Section Category restored successfully']
        );
    }

    /* =========================================================
     | Force Delete (Permanent)
     ========================================================= */

    public function forceDelete(Request $request, int $id)
    {
        $category = $this->service->findWithTrashed($id);

        $this->authorizeAction($request, $category);

        $this->service->forceDelete($id);

        return $this->deleted(
            'Section Category permanently deleted.'
        );
    }
}

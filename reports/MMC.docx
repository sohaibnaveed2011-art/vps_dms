    {
        $warehouse = $this->service->findWithTrashed($id);

        if (! $warehouse->trashed()) {
            throw new NotFoundException(
                'Warehouse not found or not deleted.'
            );
        }

        $this->authorizeAction($request, $warehouse);

        $this->service->restore($id);

        return $this->success(
            ['message' => 'Warehouse restored successfully.']
        );
    }
}

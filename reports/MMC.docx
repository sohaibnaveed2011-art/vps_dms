namespace App\Http\Controllers\v1\api\Core;

use App\Exceptions\ForbiddenException;
use App\Exceptions\NotFoundException;
use App\Http\Controllers\v1\api\BaseApiController;
use App\Http\Requests\Core\StoreOrganizationRequest;
use App\Http\Requests\Core\UpdateOrganizationRequest;
use App\Http\Resources\Core\OrganizationResource;
use App\Services\Core\OrganizationService;
use Illuminate\Http\Request;

class OrganizationController extends BaseApiController
{
    public function __construct(
        protected OrganizationService $service
    ) {
        parent::__construct(app(\App\Services\Auth\AuthorizationService::class));
    }

    /* =========================================================
     | List
     ========================================================= */

    public function index(Request $request)
    {
        $this->authorizeAction($request);

        $user = $request->user();

        $filters = [];

        if (! $user->is_admin) {
            $context = $user->activeContext();

            if (! $context) {
                throw new NotFoundException('Organization not found.');
            }

            // Non-admin can only view his own organization
            $filters['id'] = $context->organization_id;
        }

        $perPage = min(
            max((int) $request->input('per_page', 15), 1),
            100
        );

        $organizations = $this->service->paginate($filters, $perPage);

        // Extra safety: if non-admin and no result → not found
        if (! $user->is_admin && $organizations->isEmpty()) {
            throw new NotFoundException('Organization not found.');
        }

        return $this->success(
            OrganizationResource::collection($organizations->items()),
            [
                'total' => $organizations->total(),
                'per_page' => $organizations->perPage(),
                'current_page' => $organizations->currentPage(),
            ]
        );
    }

    /* =========================================================
     | Create
     ========================================================= */

    public function store(StoreOrganizationRequest $request)
    {
        $this->authorizeAction($request);
        $this->ensureAdmin(
            $request,
            'Only system admin can create organizations.'
        );

        $org = $this->service->create($request->validated());

        return $this->created(
            ['message' => 'Organization created successfully.']
        );
    }

    /* =========================================================
     | Show
     ========================================================= */

    public function show(Request $request, int $id)
    {
        $this->authorizeAction($request);

        $user = $request->user();

        if (! $user->is_admin) {
            $context = $user->activeContext();

            if (! $context || $context->organization_id !== $id) {
                throw new ForbiddenException(
                    'You are not allowed to access this organization.'
                );
            }
        }

        $org = $this->service->find($id);

        return $this->success(
            new OrganizationResource($org)
        );
    }

    /* =========================================================
     | Update
     ========================================================= */

    public function update(UpdateOrganizationRequest $request, int $id)
    {
        $this->authorizeAction($request);
        $this->ensureAdmin(
            $request,
            'Only system admin can update organizations.'
        );

        $org = $this->service->find($id);

        if ($org->policies_locked && $request->has('policies_locked')) {
            throw new ForbiddenException(
                'Organization policies are already locked.'
            );
        }

        $updated = $this->service->update($id, $request->validated());

        return $this->success(
            ['message' => 'Organization updated successfully.']
        );
    }

    /* =========================================================
     | Soft Delete
     ========================================================= */

    public function destroy(Request $request, int $id)
    {
        $this->authorizeAction($request);
        $this->ensureAdmin(
            $request,
            'Only system admin can delete organizations.'
        );

        $this->service->delete($id);

        return $this->deleted(
            'Organization deleted successfully.'
        );
    }

    /* =========================================================
     | Force Delete
     ========================================================= */

    public function forceDelete(Request $request, int $id)
    {
        $this->authorizeAction($request);
        $this->ensureAdmin(
            $request,
            'Only system admin can permanently delete organizations.'
        );

        $this->service->forceDelete($id);

        return $this->deleted(
            'Organization permanently deleted.'
        );
    }

    /* =========================================================
     | Restore
     ========================================================= */

    public function restore(Request $request, int $id)
    {
        $this->authorizeAction($request);
        $this->ensureAdmin(
            $request,
            'Only system admin can restore organizations.'
        );

        $restored = $this->service->restore($id);

        return $this->success(
            ['message' => 'Organization restored successfully.']
        );
    }

    /* =========================================================
     | GLOBAL LOCK / UNLOCK
     ========================================================= */

    public function lockAll(Request $request, int $org)
    {
        $this->ensureAdmin($request);

        $this->service->lockOrganizationPolicies($org);

        return $this->success([
            'message' => 'Organization policies locked.',
        ]);
    }

    public function unlockAll(Request $request, int $org)
    {
        $this->ensureAdmin($request);

        $this->service->unlockOrganizationPolicies($org);

        return $this->success([
            'message' => 'Organization policies unlocked.',
        ]);
    }
}

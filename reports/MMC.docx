    public function __construct(
        protected PermissionService $service
    ) {}

    public function index(Request $request)
    {
        abort_unless($request->user()->is_admin, 403);

        $permissions = $this->service->list(
            $request->only('q'),
            (int) $request->get('per_page', 50)
        );

        return response()->json([
            'success' => true,
            'data' => PermissionResource::collection(
                $permissions->items()
            ),
            'meta' => [
                'total' => $permissions->total(),
            ],
        ]);
    }

    public function store(StorePermissionRequest $request)
    {
        abort_unless($request->user()->is_admin, 403);

        return response()->json([
            'success' => true,
            'data' => new PermissionResource(
                $this->service->create($request->validated())
            ),
        ], 201);
    }

    public function update(UpdatePermissionRequest $request, int $id)
    {
        abort_unless($request->user()->is_admin, 403);

        $permission = $this->service->find($id)
            ?? abort(404, 'Permission not found');

        return response()->json([
            'success' => true,
            'data' => new PermissionResource(
                $this->service->update($permission, $request->validated())
            ),
        ]);
    }

    public function destroy(int $id)
    {
        abort_unless(auth('sanctum')->user()->is_admin, 403);

        $permission = $this->service->find($id)
            ?? abort(404, 'Permission not found');
        abort(403, 'Permissions are system-managed and cannot be deleted');
        $this->service->delete($permission);

        return response()->json([
            'success' => true,
            'message' => 'Permission deleted successfully',
        ]);
    }
}
<?php

namespace App\Http\Controllers\v1\api\Auth;

use App\Http\Controllers\v1\api\BaseApiController;
use App\Http\Requests\Auth\StoreRoleRequest;
use App\Http\Requests\Auth\SyncRolePermissionsRequest;
use App\Http\Requests\Auth\UpdateRoleRequest;
use App\Http\Resources\Auth\RoleResource;
use App\Services\Auth\RoleService;
use Illuminate\Http\Request;
use Spatie\Permission\Models\Role;

class RoleController extends BaseApiController
{
    /**
     * ❌ No permission mapping
     * 🔐 Guarded by system.admin middleware
     */
    protected array $permissions = [
        'index' => null,
        'store' => null,
        'show' => null,
        'update' => null,
        'destroy' => null,
        'syncPermissions' => null,
    ];

    public function __construct(
        protected RoleService $service
    ) {
        parent::__construct(
            app(\App\Services\Auth\AuthorizationService::class)
        );
    }

    public function index(Request $request)
    {
        $roles = $this->service->list(
            $request->only('q'),
            (int) $request->get('per_page', 15)
        );

        return $this->success(
            RoleResource::collection($roles->items()),
            [
                'pagination' => [
                    'total' => $roles->total(),
                    'per_page' => $roles->perPage(),
                    'current_page' => $roles->currentPage(),
                ],
            ]
        );
    }

    public function store(StoreRoleRequest $request)
    {
        $role = $this->service->create($request->validated());

        return $this->created(
            new RoleResource($role)
        );
    }

    public function show(int $id)
    {
        $role = $this->service->find($id)
            ?? abort(404, 'Role not found');

        return $this->success(
            new RoleResource($role->load('permissions'))
        );
    }

    public function update(UpdateRoleRequest $request, int $id)
    {
        $role = $this->service->find($id)
            ?? abort(404, 'Role not found');

        return $this->success(
            new RoleResource(
                $this->service->update($role, $request->validated())
            )
        );
    }

    public function destroy(int $id)
    {
        $role = $this->service->find($id)
            ?? abort(404, 'Role not found');

        $this->service->delete($role);

        return $this->success([
            'message' => 'Role deleted successfully',
        ]);
    }

    /**
     * ✅ SINGLE ENTRY POINT
     * Sync permissions to role
     */
    public function syncPermissions(
        SyncRolePermissionsRequest $request,
        Role $role
    ) {
        // ❗ Protect admin role
        if ($role->name === 'admin') {
            abort(403, 'Admin role permissions are system-controlled');
        }

        $updated = $this->service->syncPermissions(
            $role,
            $request->validated()['permissions']
        );

        return $this->success(
            new RoleResource($updated->load('permissions'))
        );
    }
}
<?php

namespace App\Http\Controllers\v1\api\Auth;

use App\Exceptions\NotFoundException;
use App\Http\Controllers\v1\api\BaseApiController;
use App\Http\Resources\Auth\UserAssignmentResource;
use App\Services\Auth\UserAssignmentService;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\Log;

class UserAssignmentController extends BaseApiController
{
    protected array $permissions = [
        'index' => 'users.assignments.view',
        'show' => 'users.assignments.show',
        'assignRoleAt' => 'users.assignments.assignRole',
        'revokeRoleAt' => 'users.assignments.revokeRole',
    ];

    public function __construct(
        protected UserAssignmentService $service
    ) {
        parent::__construct(app(\App\Services\Auth\AuthorizationService::class));
    }

    public function index(Request $request)
    {
        $this->authorizeAction($request);

        $assignments = $request->query('user_id')
            ? $this->service->listByUser($request->query('user_id'))
            : $this->service->list();

        return $this->success(
            UserAssignmentResource::collection($assignments),
            [
                'pagination' => [
                    'total' => $assignments->total(),
                    'per_page' => $assignments->perPage(),
                    'current_page' => $assignments->currentPage(),
                ],
            ]
        );
    }

    public function show(Request $request, int $id)
    {
        $assignment = $this->service->find($id)
            ?? throw new NotFoundException( 'User assignment not found');

        $this->authorizeAction($request, $assignment);

        return $this->success(new UserAssignmentResource($assignment));
    }

    public function assignRoleAt(Request $request, int $userId)
    {
        $this->authorizeAction($request);

        $assignment = $this->service->assignRoleAt(
            $userId,
            $request->role_id,
            $request->assignable_type,
            $request->assignable_id,
            $request->user()
        );

        return $this->created(['message' => 'Role assigned successfully.']);
    }

    /**
     * Revoke (deactivate) a user assignment.
     */
    public function revokeRoleAt(Request $request, int $assignmentId)
    {
        $this->authorizeAction($request);

        $assignment = $this->service->revokeById(
            assignmentId: $assignmentId,
            actor: $request->user()
        );

        return $this->success(
            ['message' => 'Role revoked successfully.']
        );
    }

    public function myActiveAssignments(Request $request)
    {
        $user = $request->user();

        $assignments = $this->service->getActiveAssignments($user->id);

        return $this->success(
            $assignments->map(function ($a) {
                return [
                    'assignment_id' => $a->id,
                    'role' => $a->role->name,
                    'scope_type' => class_basename($a->assignable_type),
                    'scope_id' => $a->assignable_id,
                    'organization_id' => $a->assignable->organization_id ?? null,
                    'label' => match (true) {
                        $a->assignable_type === \App\Models\Core\Organization::class => 'organization',
                        $a->assignable_type === \App\Models\Core\Branch::class => 'branch',
                        $a->assignable_type === \App\Models\Core\Warehouse::class => 'warehouse',
                        $a->assignable_type === \App\Models\Core\Outlet::class => 'outlet',
                        default => 'Scope',
                    },
                ];
            })
        );
    }
}
<?php

namespace App\Http\Controllers\v1\api\Auth;

use App\Http\Controllers\v1\api\BaseApiController;
use App\Http\Resources\Auth\UserContextResource;
use App\Models\Auth\UserContext;
use Illuminate\Http\Request;

class UserContextController extends BaseApiController
{
    protected array $permissions = [
        'index' => 'users.contexts.view',
        'show'  => 'users.contexts.show',
    ];

    public function index(Request $request)
    {
        $this->authorizeAction($request);

        $contexts = UserContext::where('user_id', $request->user()->id)
            ->latest()
            ->paginate();

        return $this->success(
            UserContextResource::collection($contexts),
            [
                'pagination' => [
                    'total'        => $contexts->total(),
                    'per_page'     => $contexts->perPage(),
                    'current_page' => $contexts->currentPage(),
                ],
            ]
        );
    }

    public function show(Request $request, int $id)
    {
        $context = UserContext::where('user_id', $request->user()->id)
            ->findOrFail($id);

        $this->authorizeAction($request, $context);

        return $this->success(new UserContextResource($context));
    }

    public function available(Request $request)
    {
        $user = $request->user();

        $assignments = UserAssignment::with('assignable')
            ->where('user_id', $user->id)
            ->whereNull('ended_at')
            ->get();

        $contexts = $assignments
            ->map(function ($a) {

                return [
                    'organization_id' => $a->assignable->organization_id ?? $a->assignable->id,
                    'branch_id' => $a->assignable->branch_id ?? null,
                    'warehouse_id' => $a->assignable->warehouse_id ?? null,
                    'outlet_id' => $a->assignable->outlet_id ?? null,
                    'label' => class_basename($a->assignable_type),
                    'scope_id' => $a->assignable_id,
                ];
            })
            ->unique(fn ($c) => json_encode([
                $c['organization_id'],
                $c['branch_id'],
                $c['warehouse_id'],
                $c['outlet_id'],
            ]))
            ->values();

        return $this->success($contexts);
    }
}

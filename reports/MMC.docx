namespace App\Http\Controllers\v1\api\Core;

use App\Exceptions\ForbiddenException;
use App\Guards\PolicyGuard;
use App\Http\Controllers\v1\api\BaseApiController;
use App\Http\Requests\Core\StoreBranchRequest;
use App\Http\Requests\Core\UpdateBranchRequest;
use App\Http\Resources\Core\BranchResource;
use App\Services\Core\BranchService;
use Illuminate\Http\Request;

class BranchController extends BaseApiController
{
    protected array $permissions = [
        'index' => 'core.branch.view',
        'store' => 'core.branch.create',
        'show' => 'core.branch.show',
        'update' => 'core.branch.update',
        'destroy' => 'core.branch.destroy',
        'forceDelete' => 'core.branch.forceDelete',
        'restore' => 'core.branch.restore',
    ];

    public function __construct(
        protected BranchService $service,
        protected PolicyGuard $policyGuard
    ) {
        parent::__construct(app(\App\Services\Auth\AuthorizationService::class));
    }

    /* =========================================================
     | List
     ========================================================= */

    public function index(Request $request)
    {
        $this->authorizeAction($request);

        $filters = $request->only([
            'search',
            'is_active',
        ]);

        $this->restrictToContext($request, $filters);

        $perPage = min(
            max((int) $request->input('per_page', 15), 1),
            100
        );

        $branches = $this->service->paginate($filters, $perPage);

        return $this->success(
            BranchResource::collection($branches->items()),
            [
                'total' => $branches->total(),
                'per_page' => $branches->perPage(),
                'current_page' => $branches->currentPage(),
            ]
        );
    }

    /* =========================================================
     | Create
     ========================================================= */

    public function store(StoreBranchRequest $request)
    {
        $this->authorizeAction($request);

        $user = $request->user();

        // 🔥 SYSTEM ADMIN BYPASS
        if (! $user->is_admin) {

            $context = $user->activeContext();

            if (! $context) {
                throw new ForbiddenException('No active context.');
            }

            $orgId = $context->organization_id;

            // 1️⃣ Ensure branch hierarchy enabled
            $this->policyGuard->requireHierarchy(
                $orgId,
                'branch'
            );

            // 2️⃣ Count existing branches (ignore soft deleted if applicable)
            $currentCount = \App\Models\Core\Branch::query()
                ->where('organization_id', $orgId)
                ->when(
                    in_array(\Illuminate\Database\Eloquent\SoftDeletes::class, class_uses(\App\Models\Core\Branch::class)),
                    fn ($q) => $q->whereNull('deleted_at')
                )
                ->count();

            // 3️⃣ Enforce limit
            $this->policyGuard->requireWithinLimit(
                $orgId,
                'branch',
                $currentCount
            );
        }

        $this->service->create($request->validated());

        return $this->created([
            'message' => 'Branch created successfully.'
        ]);
    }

    /* =========================================================
     | Show
     ========================================================= */

    public function show(Request $request, int $id)
    {
        $branch = $this->service->find($id);

        $this->authorizeAction($request, $branch);

        return $this->success(
            new BranchResource($branch)
        );
    }

    /* =========================================================
     | Update
     ========================================================= */

    public function update(UpdateBranchRequest $request, int $id)
    {
        $branch = $this->service->find($id);

        $this->authorizeAction($request, $branch);

        $this->service->update($id, $request->validated());

        return $this->success(
            ['message' => 'Branch updated successfully.']
        );
    }

    /* =========================================================
     | Soft Delete
     ========================================================= */

    public function destroy(Request $request, int $id)
    {
        $branch = $this->service->find($id);

        $this->authorizeAction($request, $branch);

        $this->service->delete($id);

        return $this->deleted(
            'Branch deleted successfully.'
        );
    }

    /* =========================================================
     | Force Delete
     ========================================================= */

    public function forceDelete(Request $request, int $id)
    {
        $branch = $this->service->findWithTrashed($id);

        $this->authorizeAction($request, $branch);

        $this->service->forceDelete($id);

        return $this->deleted(
            'Branch permanently deleted.'
        );
    }

    /* =========================================================
     | Restore
     ========================================================= */

    public function restore(Request $request, int $id)
    {
        $branch = $this->service->findWithTrashed($id);

        if (! $branch->trashed()) {
            throw new \App\Exceptions\NotFoundException(
                'Branch not found or not deleted.'
            );
        }

        $this->authorizeAction($request, $branch);

        $this->service->restore($id);

        return $this->success(
            ['message' => 'Branch restored successfully.']
        );
    }
}
